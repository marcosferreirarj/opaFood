# ============================================================
# Firebase CLIENT SDK  (exposto ao browser — prefixo NEXT_PUBLIC_)
# Copie do Firebase Console > Configurações do Projeto > Seus apps
# ============================================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ============================================================
# Firebase ADMIN SDK  (apenas servidor — NUNCA expor ao browser)
# Gere em Firebase Console > Configurações > Contas de serviço
# > Gerar nova chave privada > salve como JSON e extraia os campos abaixo
# ============================================================
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Cole a chave entre aspas, com \n literais — ex: "-----BEGIN PRIVATE KEY-----\nABC...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=

# ============================================================
# Painel Admin  (apenas servidor — NUNCA expor ao browser)
# UID do usuário Firebase Auth que terá acesso ao painel /admin
# Encontre em Firebase Console > Authentication > Users > UID
# ============================================================
ADMIN_UID=

# ============================================================
# Modo Desenvolvedor  (apenas local — NUNCA habilite em produção)
# ============================================================
# Habilita o botão "Entrar como Desenvolvedor" na tela de login
NEXT_PUBLIC_DEV_LOGIN=false
# UID que será usado como "ownerId" da loja de teste no Firestore
# Deve corresponder ao campo ownerId de um documento em /stores
NEXT_PUBLIC_DEV_UID=dev-user-001
